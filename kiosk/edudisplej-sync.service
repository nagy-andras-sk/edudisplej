[Unit]
Description=EduDisplej Sync
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/opt/edudisplej/init/edudisplej_sync_service.sh
Restart=always
RestartSec=5
User=root
Environment=EDUDISPLEJ_API_URL=https://control.edudisplej.sk
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/edudisplej/.Xauthority
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
